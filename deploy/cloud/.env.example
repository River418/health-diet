# ==================== 数据库配置 ====================
POSTGRES_USER=healthdiet
POSTGRES_PASSWORD=change_this_secure_postgres_password
POSTGRES_DB=health_diet

# ==================== Redis配置 ====================
REDIS_PASSWORD=change_this_secure_redis_password

# ==================== 服务端口 ====================
# 注意：与 novel-writer 部署在同一服务器，使用不同端口避免冲突
BACKEND_PORT=3100
H5_PORT=3101
ADMIN_PORT=3102

# ==================== JWT配置 ====================
JWT_SECRET=change_this_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==================== SSL (Cloudflare DNS-01) ====================
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CERTBOT_EMAIL=your-email@example.com
CERTBOT_DOMAIN=health-diet.instory.tech
CERTBOT_WILDCARD=true
CERTBOT_PROPAGATION_SECONDS=60

# ==================== 微信小程序配置 ====================
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# ==================== 抖音小程序配置 ====================
DOUYIN_APP_ID=your-douyin-app-id
DOUYIN_APP_SECRET=your-douyin-app-secret

# ==================== CORS配置 ====================
CORS_ORIGIN=https://health-diet.instory.tech,https://admin.health-diet.instory.tech

# ==================== 前端环境变量 ====================
TARO_APP_API_URL=https://health-diet.instory.tech/api/v1
NEXT_PUBLIC_API_URL=https://health-diet.instory.tech/api/v1

# ==================== 其他配置 ====================
TZ=Asia/Shanghai
LOG_LEVEL=info

# ==================== 部署行为 ====================
AUTO_PULL_LATEST=ask