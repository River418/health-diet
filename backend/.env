# 服务器配置
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# JWT配置
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 数据库配置 - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=health_diet

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 微信小程序配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 抖音小程序配置
DOUYIN_APP_ID=your-douyin-app-id
DOUYIN_APP_SECRET=your-douyin-app-secret

# CORS配置
CORS_ORIGIN=*

# 日志级别
LOG_LEVEL=info

# 消息队列配置
MQ_ENABLED=false
MQ_URL=amqp://localhost
